# macOS code signing + notarization credentials for `pnpm tauri build`.
#
# Copy this file to `.env.signing` (git-ignored), fill in the values, then run:
#     ./scripts/macos-sign-build.sh
#
# `pnpm tauri build` picks these up as environment variables and, when they are
# set, signs the .app with hardened runtime, submits it to Apple's notary
# service, and staples the ticket automatically.
#
# Prerequisites (see AGENTS.md "Releasing (macOS signing)"):
#   - Xcode Command Line Tools installed (`xcode-select --install`).
#   - A "Developer ID Application" certificate + its private key present in your
#     login keychain. Verify with:  security find-identity -v -p codesigning
#     Only "Developer ID Application" works for distribution outside the App
#     Store — "Apple Development" / "Apple Distribution" certs cannot be notarized.

# --- Signing ---------------------------------------------------------------
# Which certificate to sign with. Use the certificate's SHA-1 hash (unambiguous)
# or its full common name ("Developer ID Application: <Name> (<TEAMID>)").
export APPLE_SIGNING_IDENTITY="XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# --- Notarization (App-specific password) ----------------------------------
# The Apple ID that owns the signing team, an app-specific password for it
# (generated at https://appleid.apple.com > Sign-In and Security >
# App-Specific Passwords), and the 10-character team ID.
export APPLE_ID="you@example.com"
export APPLE_PASSWORD="xxxx-xxxx-xxxx-xxxx"
export APPLE_TEAM_ID="XXXXXXXXXX"
