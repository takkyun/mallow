{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mallow",
  "version": "0.1.0",
  "identifier": "net.serenebach.mallow",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "mallow",
        "width": 1100,
        "height": 720,
        "minWidth": 640,
        "minHeight": 420
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Takuya Otani",
    "homepage": "https://github.com/takkyun/mallow",
    "copyright": "Copyright © 2026 Takuya Otani",
    "license": "MIT",
    "category": "DeveloperTool",
    "shortDescription": "Lightweight Markdown / config-file viewer",
    "longDescription": "A lightweight desktop Markdown and config-file (JSON / YAML / TOML) viewer built with Tauri v2.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
